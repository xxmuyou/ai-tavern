# Image generation
IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_PUBLIC_BASE_URL=http://127.0.0.1:8787
RUNNINGHUB_BASE_URL=https://www.runninghub.ai
RUNNINGHUB_API_KEY=

# WF-1 create (txt2img base companion portrait).
# This is the per-style technical wiring (workflowId + node ids). The list of
# selectable MODELS shown in the create form lives in the admin-editable
# `image_models` table (seeded by migration 0023): each model carries a
# style_tag + ckpt_name, and the chosen model's ckpt_name overrides ckptName
# below at generation time. `checkpointNodeId` MUST be set per style for model
# switching to take effect (without it the workflow's baked-in checkpoint wins).
# Upload runninghub-wf1-create.workflow_api.json to RunningHub, run it once,
# then replace <WF1_WORKFLOW_ID>. Node ids match the generated workflow JSON:
# checkpoint node=1 (ckpt_name), prompt node=2 (text).
RUNNINGHUB_CREATE_WORKFLOWS={"realistic":{"workflowId":"<WF1_WORKFLOW_ID>","promptNodeId":"2","checkpointNodeId":"1","ckptName":"juggernautXL_ragnarokBy.safetensors"},"anime_jp":{"workflowId":"<WF1_WORKFLOW_ID>","promptNodeId":"2","checkpointNodeId":"1","ckptName":"animagineXL40_v4Opt.safetensors"},"anime_kr":{"workflowId":"<WF1_WORKFLOW_ID>","promptNodeId":"2","checkpointNodeId":"1","ckptName":"ghostxl_v10BakedVAE.safetensors"}}

# WF-2 variation (img2img emotion/pose portrait + cutout).
# Used to generate the 5 non-neutral emotion variants from a neutral base image.
# The pose/expression PROMPTS are admin-editable per gender × emotion in the
# `expression_prompts` table (seeded by migration 0023); this section is only
# the technical wiring. Code overrides the load-image url + prompt nodes.
# Upload runninghub-wf2-variation-cutout.workflow_api.json to RunningHub, run it
# once, then set RUNNINGHUB_WORKFLOW_ID + the load-image / prompt node ids.
RUNNINGHUB_WORKFLOW_ID=
RUNNINGHUB_LOAD_IMAGE_NODE_ID=2
RUNNINGHUB_PROMPT_NODE_ID=5
RUNNINGHUB_WEBHOOK_URL=http://127.0.0.1:8787/webhooks/runninghub
RUNNINGHUB_WEBHOOK_SECRET=
R2_SIGNING_KEY=
