# xtbit-apps env schema
#
# Copy to one target only:
#   .env.local  -> local machine only
#   .env.dev    -> remote dev only
#   .env.prod   -> production only
#
# This file is a schema, not a runnable config. URL fields are intentionally
# blank so local, dev, and prod values do not get mixed.

# -------------------------------------------------------------------
# Public client config
# Scope: local / dev / prod
# EXPO_PUBLIC_* values are compiled into the Web/App client. Do not put secrets
# here.
# -------------------------------------------------------------------
# Fill with the API base URL for the target environment.
EXPO_PUBLIC_API_URL=

# Analytics defaults to production-only when unset. Set to 1/true to force-enable
# in dev testing, or 0/false to force-disable.
EXPO_PUBLIC_ANALYTICS_ENABLED=

# Google Ads conversion tag config. Values come from Google Ads -> Goals ->
# Conversions -> the selected conversion action's tag snippet.
# Example ID shape: AW-123456789
EXPO_PUBLIC_GOOGLE_ADS_ID=
EXPO_PUBLIC_GOOGLE_ADS_SIGNUP_LABEL=
EXPO_PUBLIC_GOOGLE_ADS_FIRST_CHAT_LABEL=
EXPO_PUBLIC_GOOGLE_ADS_CHAT_3_MESSAGES_LABEL=
EXPO_PUBLIC_GOOGLE_ADS_CHECKOUT_STARTED_LABEL=
EXPO_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=

# -------------------------------------------------------------------
# Cloudflare deploy credentials
# Scope: dev / prod only
# Used by deploy/sync scripts. Not exposed to Worker runtime.
# -------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# -------------------------------------------------------------------
# Public web root (single source for derived URLs)
# Scope: local / dev / prod
# Code derives CORS origins, auth/billing redirects and the image webhook
# from this one origin. Set it per environment, e.g.
#   local: http://localhost:8081
#   dev:   https://dev.aiappsbox.com
#   prod:  https://aiappsbox.com
# -------------------------------------------------------------------
APP_BASE_URL=

# -------------------------------------------------------------------
# Auth, admin, CORS
# Scope: local / dev / prod
# -------------------------------------------------------------------
ADMIN_EMAILS=admin@aiappsbox.com
# Escape hatch: uncomment to override the value derived from APP_BASE_URL.
# ALLOWED_ORIGINS=
# AUTH_SUCCESS_URL=

# Secrets. Admin UI shows configured/missing only.
AUTH_TOKEN_SECRET=
JWT_SIGNING_KEY=

# Google login. Optional for local direct-login flows; required for real OAuth.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -------------------------------------------------------------------
# Email / magic link
# Scope: local / dev / prod
# -------------------------------------------------------------------
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=

# -------------------------------------------------------------------
# Safety limits
# Scope: local / dev / prod
# -------------------------------------------------------------------
REQUEST_BODY_LIMIT_BYTES=262144
ASSET_UPLOAD_BODY_LIMIT_BYTES=5242880
STRIPE_WEBHOOK_BODY_LIMIT_BYTES=1048576
RATE_LIMIT_PER_MINUTE=120
LLM_RATE_LIMIT_PER_MINUTE=30

# -------------------------------------------------------------------
# Stripe
# Scope: local / dev / prod
# Use test mode for local/dev and live mode for prod.
# URL fields must match the target environment.
# -------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_CREDITS_SMALL=
STRIPE_PRICE_CREDITS_MEDIUM=
STRIPE_PRICE_CREDITS_LARGE=

# Checkout/portal redirect URLs are derived from APP_BASE_URL.
# Escape hatch: uncomment to override per environment.
# STRIPE_SUCCESS_URL=
# STRIPE_CANCEL_URL=
# STRIPE_PORTAL_RETURN_URL=
# STRIPE_CREDITS_SUCCESS_URL=
# STRIPE_CREDITS_CANCEL_URL=

# -------------------------------------------------------------------
# LLM provider keys
# Scope: local / dev / prod
# Provider/model routing is managed in admin.
# -------------------------------------------------------------------
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# Doubao / Volcano Engine ARK (OpenAI-compatible). Key for the doubao provider.
ARK_API_KEY=
# MiniMax OpenAI-compatible chat provider. Uses https://api.minimaxi.com/v1, not api.minimax.io.
MINIMAX_API_KEY=
# MiniMax T2A non-secret config lives in config/minimax-voices.<env>.json.

# -------------------------------------------------------------------
# Image generation
# Scope: local / dev / prod
# Secret values stay in env/Wrangler; admin only shows status.
# -------------------------------------------------------------------
IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_WF1_PROVIDER=
IMAGE_GEN_WF2_PROVIDER=
IMAGE_GEN_WF1_BASE_PROMPT=

OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# Escape hatch: derived from APP_BASE_URL as {origin}/api.
# IMAGE_GEN_PUBLIC_BASE_URL=
RUNNINGHUB_BASE_URL=https://www.runninghub.ai
RUNNINGHUB_MAX_ACTIVE_TASKS=3
RUNNINGHUB_API_KEY=

# RunningHub workflow/node ids, checkpoint field names, and default checkpoint
# file names are not env vars. They live in config/runninghub-workflows.dev.json
# and config/runninghub-workflows.prod.json, then deploy syncs them into D1
# app_settings.
# Escape hatch: derived from APP_BASE_URL as {origin}/api/webhooks/runninghub.
# RUNNINGHUB_WEBHOOK_URL=
RUNNINGHUB_WEBHOOK_SECRET=
R2_SIGNING_KEY=
