{
  "$schema": "../../packages/api/node_modules/wrangler/config-schema.json",
  "name": "xtbit-apps-api",
  "main": "../../packages/api/src/index.ts",
  "compatibility_date": "2026-05-13",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": false,
  "routes": [
    {
      "pattern": "dev.aiappsbox.com/api/*",
      "zone_name": "aiappsbox.com"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "APP_ENV": "dev",
    "ALLOWED_ORIGINS": "http://localhost:8081,http://127.0.0.1:8081,https://dev.xtbit-apps.pages.dev,https://dev.aiappsbox.com",
    "ADMIN_EMAILS": "admin@aiappsbox.com",
    "REQUEST_BODY_LIMIT_BYTES": "262144",
    "ASSET_UPLOAD_BODY_LIMIT_BYTES": "5242880",
    "STRIPE_WEBHOOK_BODY_LIMIT_BYTES": "1048576",
    "RATE_LIMIT_PER_MINUTE": "120",
    "LLM_RATE_LIMIT_PER_MINUTE": "30",
    "DEV_AUTH_TOKEN_TTL_SECONDS": "28800",
    "STRIPE_PUBLISHABLE_KEY": "",
    "STRIPE_PRICE_PRO_MONTHLY": "",
    "STRIPE_SUCCESS_URL": "https://dev.xtbit-apps.pages.dev/?billing=success",
    "STRIPE_CANCEL_URL": "https://dev.xtbit-apps.pages.dev/?billing=cancelled",
    "STRIPE_PORTAL_RETURN_URL": "https://dev.xtbit-apps.pages.dev/?billing=portal"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "xtbit-apps-dev",
      "database_id": "e3c49f74-c337-4b49-8c78-88c01a908c64",
      "migrations_dir": "../../packages/api/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "xtbit-apps-dev-assets"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CONFIG",
      "id": "48a69782e2574e13a6b2df71f5b456f7"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "JOB_QUEUE",
        "queue": "xtbit-apps-dev-jobs"
      }
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "GameRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "GameRoom"
      ]
    }
  ],
  "env": {
    "production": {
      "name": "xtbit-apps-api-prod",
      "routes": [
        {
          "pattern": "aiappsbox.com/api/*",
          "zone_name": "aiappsbox.com"
        }
      ],
      "vars": {
        "APP_ENV": "prod",
        "ALLOWED_ORIGINS": "https://aiappsbox.com",
        "ADMIN_EMAILS": "admin@aiappsbox.com",
        "REQUEST_BODY_LIMIT_BYTES": "262144",
        "ASSET_UPLOAD_BODY_LIMIT_BYTES": "5242880",
        "STRIPE_WEBHOOK_BODY_LIMIT_BYTES": "1048576",
        "RATE_LIMIT_PER_MINUTE": "120",
        "LLM_RATE_LIMIT_PER_MINUTE": "30",
        "DEV_AUTH_TOKEN_TTL_SECONDS": "28800",
        "STRIPE_PUBLISHABLE_KEY": "",
        "STRIPE_PRICE_PRO_MONTHLY": "",
        "STRIPE_SUCCESS_URL": "https://aiappsbox.com/?billing=success",
        "STRIPE_CANCEL_URL": "https://aiappsbox.com/?billing=cancelled",
        "STRIPE_PORTAL_RETURN_URL": "https://aiappsbox.com/?billing=portal"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "xtbit-apps-prod",
          "database_id": "14a9ebf0-69f0-4599-b6bf-a832211865e9",
          "migrations_dir": "../../packages/api/migrations"
        }
      ],
      "r2_buckets": [
        {
          "binding": "ASSETS",
          "bucket_name": "xtbit-apps-prod-assets"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "CONFIG",
          "id": "4265d3978ef149dba26c987285f81d2f"
        }
      ],
      "queues": {
        "producers": [
          {
            "binding": "JOB_QUEUE",
            "queue": "xtbit-apps-prod-jobs"
          }
        ]
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "ROOMS",
            "class_name": "GameRoom"
          }
        ]
      }
    }
  }
}
