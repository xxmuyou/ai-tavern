{
  "$schema": "../../packages/api/node_modules/wrangler/config-schema.json",
  "name": "xtbit-apps-api",
  "main": "../../packages/api/src/index.ts",
  "compatibility_date": "2026-05-13",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": false,
  "routes": [
    {
      "pattern": "dev.aiappsbox.com/api/*",
      "zone_name": "aiappsbox.com"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "APP_ENV": "dev",
    "APP_BASE_URL": "https://dev.aiappsbox.com",
    "ADMIN_EMAILS": "admin@aiappsbox.com",
    "REQUEST_BODY_LIMIT_BYTES": "262144",
    "ASSET_UPLOAD_BODY_LIMIT_BYTES": "5242880",
    "STRIPE_WEBHOOK_BODY_LIMIT_BYTES": "1048576",
    "RATE_LIMIT_PER_MINUTE": "120",
    "LLM_RATE_LIMIT_PER_MINUTE": "30",
    "IMAGE_GEN_PROVIDER": "runninghub",
    "RUNNINGHUB_BASE_URL": "https://www.runninghub.ai",
    "STRIPE_PUBLISHABLE_KEY": "",
    "GOOGLE_OAUTH_CLIENT_ID": "285229330091-i88vp1sic03pkohr5k1prumtn2233c74.apps.googleusercontent.com"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "xtbit-apps-dev",
      "database_id": "e3c49f74-c337-4b49-8c78-88c01a908c64",
      "migrations_dir": "../../packages/api/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "xtbit-apps-dev-assets"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CONFIG",
      "id": "48a69782e2574e13a6b2df71f5b456f7"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "JOB_QUEUE",
        "queue": "xtbit-apps-dev-jobs"
      }
    ],
    "consumers": [
      {
        "queue": "xtbit-apps-dev-jobs",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3
      }
    ]
  },
  "triggers": {
    "crons": [
      "*/5 * * * *"
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "GameRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "GameRoom"
      ]
    }
  ],
  "env": {
    "prod": {
      "name": "xtbit-apps-api-prod",
      "routes": [
        {
          "pattern": "aiappsbox.com/api/*",
          "zone_name": "aiappsbox.com"
        }
      ],
      "vars": {
        "APP_ENV": "prod",
        "APP_BASE_URL": "https://aiappsbox.com",
        "ADMIN_EMAILS": "admin@aiappsbox.com",
        "REQUEST_BODY_LIMIT_BYTES": "262144",
        "ASSET_UPLOAD_BODY_LIMIT_BYTES": "5242880",
        "STRIPE_WEBHOOK_BODY_LIMIT_BYTES": "1048576",
        "RATE_LIMIT_PER_MINUTE": "120",
        "LLM_RATE_LIMIT_PER_MINUTE": "30",
        "IMAGE_GEN_PROVIDER": "runninghub",
        "RUNNINGHUB_BASE_URL": "https://www.runninghub.ai",
        "STRIPE_PUBLISHABLE_KEY": "",
        "GOOGLE_OAUTH_CLIENT_ID": "285229330091-i88vp1sic03pkohr5k1prumtn2233c74.apps.googleusercontent.com"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "xtbit-apps-prod",
          "database_id": "14a9ebf0-69f0-4599-b6bf-a832211865e9",
          "migrations_dir": "../../packages/api/migrations"
        }
      ],
      "r2_buckets": [
        {
          "binding": "ASSETS",
          "bucket_name": "xtbit-apps-prod-assets"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "CONFIG",
          "id": "4265d3978ef149dba26c987285f81d2f"
        }
      ],
      "queues": {
        "producers": [
          {
            "binding": "JOB_QUEUE",
            "queue": "xtbit-apps-prod-jobs"
          }
        ],
        "consumers": [
          {
            "queue": "xtbit-apps-prod-jobs",
            "max_batch_size": 10,
            "max_batch_timeout": 30,
            "max_retries": 3
          }
        ]
      },
      "triggers": {
        "crons": [
          "*/5 * * * *"
        ]
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "ROOMS",
            "class_name": "GameRoom"
          }
        ]
      }
    }
  }
}
