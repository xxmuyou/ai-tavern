{
  "name": "xtbit-apps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "local-env": "bash ./scripts/prepare-local-env.sh local",
    "local-env:local": "bash ./scripts/prepare-local-env.sh local",
    "local-env:dev": "bash ./scripts/prepare-local-env.sh dev",
    "local-env:prod": "bash ./scripts/prepare-local-env.sh prod",
    "local": "bash ./scripts/local-dev.sh",
    "local:app": "bash ./scripts/tasks/run.sh app:local",
    "local:api": "bash ./scripts/tasks/run.sh api:local",
    "dev": "bash -c 'echo \"pnpm dev is disabled to avoid local/dev confusion. Use pnpm local for local development.\" >&2; exit 1'",
    "dev:app": "bash -c 'echo \"pnpm dev:app is disabled. Use pnpm local:app.\" >&2; exit 1'",
    "dev:api": "bash -c 'echo \"pnpm dev:api is disabled. Use pnpm local:api.\" >&2; exit 1'",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @xtbit/api test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "cf:types": "bash ./scripts/tasks/run.sh api:cf-types",
    "cf:d1:migrate:local": "bash ./scripts/tasks/run.sh api:d1-migrate-local",
    "cf:d1:migrate:dev": "bash ./scripts/tasks/run.sh api:d1-migrate-dev",
    "cf:d1:migrate:prod": "bash ./scripts/tasks/run.sh api:d1-migrate-prod",
    "cf:secrets:dev": "bash ./scripts/sync-wrangler-secrets.sh dev",
    "cf:secrets:prod": "bash ./scripts/sync-wrangler-secrets.sh prod",
    "deploy:dev": "bash ./scripts/deploy.sh dev",
    "deploy:prod": "bash ./scripts/deploy.sh prod",
    "deploy:api:dev": "bash ./scripts/tasks/run.sh api:deploy-dev",
    "deploy:api:prod": "bash ./scripts/tasks/run.sh api:deploy-prod",
    "deploy:web:dev": "bash ./scripts/tasks/run.sh deploy:web-dev",
    "deploy:web:prod": "bash ./scripts/tasks/run.sh deploy:web-prod",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.1.3"
}
