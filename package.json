{
  "name": "xtbit-apps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:env": "bash ./scripts/generate-env-files.sh local",
    "generate:env:local": "bash ./scripts/generate-env-files.sh local",
    "generate:env:dev": "bash ./scripts/generate-env-files.sh dev",
    "generate:env:prod": "bash ./scripts/generate-env-files.sh prod",
    "run:local": "bash ./scripts/run-local-stack.sh",
    "run:local:app": "bash ./scripts/tasks/run.sh app:local",
    "run:local:api": "bash ./scripts/tasks/run.sh api:local",
    "dev": "bash -c 'echo \"pnpm dev is disabled to avoid local/dev confusion. Use pnpm run:local for local development.\" >&2; exit 1'",
    "dev:app": "bash -c 'echo \"pnpm dev:app is disabled. Use pnpm run:local:app.\" >&2; exit 1'",
    "dev:api": "bash -c 'echo \"pnpm dev:api is disabled. Use pnpm run:local:api.\" >&2; exit 1'",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @xtbit/api test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "generate:cf-types": "bash ./scripts/tasks/run.sh api:cf-types",
    "migrate:db:local": "bash ./scripts/tasks/run.sh api:d1-migrate-local",
    "migrate:db:dev": "bash ./scripts/tasks/run.sh api:d1-migrate-dev",
    "migrate:db:prod": "bash ./scripts/tasks/run.sh api:d1-migrate-prod",
    "sync:runninghub:dev": "bash ./scripts/tasks/run.sh api:sync-runninghub-dev",
    "sync:runninghub:prod": "bash ./scripts/tasks/run.sh api:sync-runninghub-prod",
    "upload:secrets:dev": "bash ./scripts/upload-worker-secrets.sh dev",
    "upload:secrets:prod": "bash ./scripts/upload-worker-secrets.sh prod",
    "deploy:dev": "bash ./scripts/deploy-api-and-web.sh dev",
    "deploy:prod": "bash ./scripts/deploy-api-and-web.sh prod",
    "deploy:api:dev": "bash ./scripts/tasks/run.sh api:deploy-dev",
    "deploy:api:prod": "bash ./scripts/tasks/run.sh api:deploy-prod",
    "deploy:web:dev": "bash ./scripts/tasks/run.sh deploy:web-dev",
    "deploy:web:prod": "bash ./scripts/tasks/run.sh deploy:web-prod",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.1.3"
}
