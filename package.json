{
  "name": "xtbit-apps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/local-dev.mjs",
    "dev:app": "node ./scripts/tasks/run.mjs app:web",
    "dev:api": "node ./scripts/tasks/run.mjs api:dev",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @xtbit/api test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "cf:types": "node ./scripts/tasks/run.mjs api:cf-types",
    "cf:d1:migrate:local": "node ./scripts/tasks/run.mjs api:d1-migrate-local",
    "cf:d1:migrate:dev": "node ./scripts/tasks/run.mjs api:d1-migrate-dev",
    "cf:d1:migrate:prod": "node ./scripts/tasks/run.mjs api:d1-migrate-prod",
    "cf:secrets:dev": "node ./scripts/cloudflare/upload-dev-secrets.mjs",
    "deploy:api:dev": "node ./scripts/tasks/run.mjs api:deploy-dev",
    "deploy:web:dev": "node ./scripts/tasks/run.mjs deploy:web-dev"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.1.3"
}
